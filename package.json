{
  "name": "crypto-sdk-api-server",
  "version": "0.0.1",
  "description": "Multi-blockchain API server supporting EVM, Cosmos, and Polkadot networks",
  "main": "index.js",
  "scripts": {
    "clean:dist": "rimraf ./dist",
    "clean:modules": "rimraf ./node_modules",
    "clean": "npm run clean:dist && npm run clean:modules",
    "lint": "npx eslint src/**/*.ts",
    "lint:fix": "npx eslint --fix src/**/*.ts && npx eslint --fix test/**/*.ts",
    "fmt": "npx prettier . --write",
    "prebuild": "npm run clean:dist",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "start:prod": "NODE_ENV=production node dist/src/index.js",
    "pretest": "npm run build",
    "test": "mocha dist/test/**/*.js",
    "test:dev": "ts-mocha test/**/*.spec.ts -w --watch-files '**/*.ts'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/chai": "^4.3.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/lodash": "^4.14.188",
    "@types/mocha": "^10.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^18.11.9",
    "@types/sinon": "^10.0.13",
    "@typescript-eslint/eslint-plugin": "^5.42.1",
    "@typescript-eslint/parser": "^5.42.1",
    "chai": "^4.3.7",
    "eslint": "^8.27.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.9",
    "mocha": "^10.1.0",
    "prettier": "3.3.3",
    "rimraf": "^3.0.2",
    "sinon": "^14.0.2",
    "ts-mocha": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.8.4"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^2.0.0",
    "@cosmjs/stargate": "^0.33.1",
    "@cosmos-client/core": "^0.47.4",
    "@polkadot/api": "^16.0.1",
    "axios": "^1.9.0",
    "bignumber.js": "^9.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ethers": "^6.14.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  }
}
